rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function isValidAmount(amount) {
      return amount is number && amount >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /expenses/{expenseId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidAmount(request.resource.data.amount);
      allow update: if isDocOwner() && request.resource.data.userId == request.auth.uid && isValidAmount(request.resource.data.amount);
      allow delete: if isDocOwner();
    }
    
    match /income/{incomeId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidAmount(request.resource.data.amount);
      allow update: if isDocOwner() && request.resource.data.userId == request.auth.uid && isValidAmount(request.resource.data.amount);
      allow delete: if isDocOwner();
    }
    
    match /budgets/{budgetId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidAmount(request.resource.data.amount);
      allow update: if isDocOwner() && request.resource.data.userId == request.auth.uid && isValidAmount(request.resource.data.amount);
      allow delete: if isDocOwner();
    }
    
    match /savingsGoals/{goalId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidAmount(request.resource.data.targetAmount);
      allow update: if isDocOwner() && request.resource.data.userId == request.auth.uid;
      allow delete: if isDocOwner();
    }
    
    match /bills/{billId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.userId == request.auth.uid;
      allow delete: if isDocOwner();
    }
  }
}
